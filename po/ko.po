msgid "ciadpi binary not found"
msgstr "ciadpi 실행 파일을 찾을 수 없습니다"

msgid "Invalid arguments: {}"
msgstr "잘못된 인수: {}"

msgid "Timed out waiting for proxy port"
msgstr "프록시 포트를 기다리는 동안 시간이 초과되었습니다"

msgid "Settings"
msgstr "설정"

msgid "Appearance"
msgstr "모양"

msgid "Theme"
msgstr "테마"

msgid "Follow system"
msgstr "시스템 설정 따르기"

msgid "Light"
msgstr "밝게"

msgid "Dark"
msgstr "어둡게"

msgid "Language"
msgstr "언어"

msgid "Proxy"
msgstr "프록시"

msgid "Local SOCKS5 endpoint exposed by byedpi."
msgstr "byedpi가 제공하는 로컬 SOCKS5 엔드포인트입니다."

msgid "Listen address"
msgstr "수신 주소"

msgid "Port"
msgstr "포트"

msgid "byedpi arguments"
msgstr "byedpi 인수"

msgid "Behavior"
msgstr "동작"

msgid "Connect on launch"
msgstr "실행 시 연결"

msgid "Start the proxy automatically when the app opens."
msgstr "앱이 열릴 때 프록시를 자동으로 시작합니다."

msgid "Show tray icon"
msgstr "트레이 아이콘 표시"

msgid "Requires a restart to take effect."
msgstr "적용하려면 다시 시작해야 합니다."

msgid "Close to tray"
msgstr "트레이로 닫기"

msgid "Keep running in the tray when the window is closed."
msgstr "창을 닫아도 트레이에서 계속 실행합니다."

msgid "Updates"
msgstr "업데이트"

msgid "Checks run at startup over HTTPS. Nothing else is sent."
msgstr "확인은 시작 시 HTTPS로 실행됩니다. 그 외에는 아무것도 전송되지 않습니다."

msgid "Check for application updates"
msgstr "애플리케이션 업데이트 확인"

msgid "Keep byedpi core up to date"
msgstr "byedpi 코어를 최신 상태로 유지"

msgid "Downloads the matching build from the byedpi project."
msgstr "byedpi 프로젝트에서 알맞은 빌드를 다운로드합니다."

msgid "Checking for application updates…"
msgstr "애플리케이션 업데이트 확인 중…"

msgid "Checking byedpi core…"
msgstr "byedpi 코어 확인 중…"

msgid "No byedpi core build for this architecture."
msgstr "이 아키텍처에 맞는 byedpi 코어 빌드가 없습니다."

msgid "Could not download the byedpi core."
msgstr "byedpi 코어를 다운로드할 수 없습니다."

msgid "Downloading byedpi core {}…"
msgstr "byedpi 코어 {} 다운로드 중…"

msgid "Starting…"
msgstr "시작 중…"

msgid "Main Menu"
msgstr "기본 메뉴"

msgid "About byedpi-gtk"
msgstr "byedpi-gtk 정보"

msgid "Quit"
msgstr "종료"

msgid "Hide"
msgstr "숨기기"

msgid "Show"
msgstr "표시"

msgid "Disconnect"
msgstr "연결 끊기"

msgid "Connect"
msgstr "연결"

msgid "A new version of byedpi-gtk is available: {}"
msgstr "byedpi-gtk의 새 버전이 있습니다: {}"

msgid "byedpi core updated to {}"
msgstr "byedpi 코어가 {}(으)로 업데이트되었습니다"

msgid "Could not start the proxy. Check the settings."
msgstr "프록시를 시작할 수 없습니다. 설정을 확인하세요."

msgid "Connecting…"
msgstr "연결 중…"

msgid "Connected"
msgstr "연결됨"

msgid "Disconnecting…"
msgstr "연결 끊는 중…"

msgid "Connection failed"
msgstr "연결 실패"

msgid "Disconnected"
msgstr "연결 끊김"
