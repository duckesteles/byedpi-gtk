<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.duckesteles.byedpigtk</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>byedpi-gtk</name>
  <summary>Bypass DPI restrictions with a local SOCKS proxy</summary>
  <description>
    <p>
      byedpi-gtk is a graphical frontend for byedpi, a tool that circumvents
      deep packet inspection. It runs a local SOCKS5 proxy with one click, keeps
      the byedpi core up to date, and never collects any data.
    </p>
    <ul>
      <li>One-click connect and disconnect</li>
      <li>Automatic byedpi core updates</li>
      <li>Configurable byedpi arguments</li>
      <li>Follows the system light or dark theme</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.duckesteles.byedpigtk.desktop</launchable>
  <url type="homepage">https://github.com/duckesteles/byedpi-gtk</url>
  <url type="bugtracker">https://github.com/duckesteles/byedpi-gtk/issues</url>
  <developer id="io.github.duckesteles">
    <name>duckesteles</name>
  </developer>
  <content_rating type="oars-1.1"/>
  <categories>
    <category>Network</category>
    <category>Security</category>
  </categories>
  <releases>
    <release version="1.1.2" date="2026-07-19">
      <description>
        <p>Fixed a crash on startup with libadwaita 1.5 (e.g. Ubuntu 24.04) by using a standard GTK spinner.</p>
      </description>
    </release>
    <release version="1.1.1" date="2026-07-18">
      <description>
        <p>Updated the Flatpak build to the current GNOME 50 runtime.</p>
      </description>
    </release>
    <release version="1.1.0" date="2026-07-16">
      <description>
        <p>Settings keep working even when the config cannot be saved, plus the startup, connection and browser-setup improvements from recent releases.</p>
      </description>
    </release>
    <release version="1.0.9" date="2026-07-16">
      <description>
        <p>Faster startup that no longer stalls on a slow network, clearer connection failures, and various robustness fixes.</p>
      </description>
    </release>
    <release version="1.0.8" date="2026-07-16">
      <description>
        <p>The byedpi core now updates itself to the latest upstream release automatically, and language switching is more robust.</p>
      </description>
    </release>
    <release version="1.0.7" date="2026-07-15">
      <description>
        <p>Verify the byedpi core download against a pinned checksum, and make the About dialog follow the chosen language.</p>
      </description>
    </release>
    <release version="1.0.6" date="2026-07-15">
      <description>
        <p>Added Russian, Chinese, Korean, Persian, Vietnamese and Indonesian translations, fixed the tray icon not showing in portable builds, and removed the log view.</p>
      </description>
    </release>
    <release version="1.0.5" date="2026-07-15">
      <description>
        <p>Fixed a missing module that prevented the app from starting in the packaged builds.</p>
      </description>
    </release>
    <release version="1.0.4" date="2026-07-15">
      <description>
        <p>Fixed the window not reappearing after being closed to the tray, and closing now quits by default.</p>
      </description>
    </release>
    <release version="1.0.3" date="2026-07-15">
      <description>
        <p>Added a system tray icon, instant language switching, and a log viewer in settings. Update checks now fail quietly.</p>
      </description>
    </release>
    <release version="1.0.2" date="2026-07-15">
      <description>
        <p>Fixed translations not loading in the AppImage and made the language list show every bundled language in its own name.</p>
      </description>
    </release>
    <release version="1.0.1" date="2026-07-15">
      <description>
        <p>Universal packages: every CPU architecture ships in one deb and one pacman package, with Flatpak and AppImage builds for x86_64 and aarch64.</p>
      </description>
    </release>
    <release version="1.0.0" date="2026-07-15">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>
</component>
