#!@PYTHON@
import os
import sys
import signal
import gettext

VERSION = '@VERSION@'
APP_ID = '@APP_ID@'
BAKED_PREFIX = '@prefix@'

_here = os.path.dirname(os.path.realpath(__file__))
_prefix = os.path.dirname(_here)


def _resolve(baked):
    if os.path.realpath(_prefix) == os.path.realpath(BAKED_PREFIX):
        return baked
    return os.path.join(_prefix, os.path.relpath(baked, BAKED_PREFIX))


MODULEDIR = _resolve('@moduledir@')
LOCALEDIR = _resolve('@localedir@')
PKGDATADIR = _resolve('@pkgdatadir@')

sys.path.insert(1, os.path.dirname(MODULEDIR))

signal.signal(signal.SIGINT, signal.SIG_DFL)

gettext.install('byedpi-gtk', LOCALEDIR)

if __name__ == '__main__':
    from byedpi_gtk.main import main
    sys.exit(main(VERSION, APP_ID, PKGDATADIR, LOCALEDIR))
